# ──────────────────────────────────────────────────────────────
# ForexIQ — Environment Variables Reference
# ──────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# NEVER commit .env to version control (.gitignore already excludes it).
#
# Production variables are set in two places:
#   Backend  → Render Dashboard → forexiq-api → Environment
#   Frontend → Cloudflare Pages Dashboard → forexiq → Settings → Env Vars
#              OR as GitHub Secrets for baking into the build
# ──────────────────────────────────────────────────────────────


# ── LOCAL DEV ──────────────────────────────────────────────────
# Server port (default 5000)
PORT=5000

# Node environment
NODE_ENV=development


# ── BACKEND (Render) ───────────────────────────────────────────

# Your Cloudflare Pages URL — used for CORS allow-list on the backend.
# REQUIRED in production. Without this, browser requests from Pages
# to Render will be rejected with 403 Forbidden.
#
# Where to find it:
#   Cloudflare Dashboard → Pages → forexiq → Deployments
#   Copy the "Visit site" URL, e.g. https://forexiq.pages.dev
#
# Set this in: Render Dashboard → forexiq-api → Environment → Add Env Var
ALLOWED_ORIGIN=https://forexiq.pages.dev

# If you add a custom domain on Cloudflare Pages (optional):
# Set this in: Render Dashboard → forexiq-api → Environment → Add Env Var
ALLOWED_ORIGIN_2=https://yourdomain.com

# NewsData.io free tier API key (200 requests/day)
# Get yours: https://newsdata.io → Sign Up → Dashboard → API Key
# Starts with: pub_
# Set this in: Render Dashboard → forexiq-api → Environment → Add Env Var
NEWSDATA_API_KEY=pub_your_key_here

# RENDER_EXTERNAL_URL — automatically injected by Render, DO NOT set manually.
# Used internally by the keep-alive self-ping logic.
# Example value when on Render: https://forexiq-api.onrender.com


# ── FRONTEND (Cloudflare Pages build) ──────────────────────────

# Your Render backend URL — baked into the frontend JS bundle at build time.
# The frontend uses this to know where to send /api/* requests.
#
# Where to find it:
#   Render Dashboard → forexiq-api → header shows "forexiq-api.onrender.com"
#   Full URL: https://forexiq-api.onrender.com  (no trailing slash)
#
# Set this as a GitHub Secret AND in Cloudflare Pages env vars:
#   GitHub:           Settings → Secrets → Actions → VITE_API_URL
#   Cloudflare Pages: Dashboard → Pages → forexiq → Settings →
#                     Environment Variables → Production → VITE_API_URL
#
# IMPORTANT: Variables must be prefixed VITE_ to be available in the browser.
VITE_API_URL=https://forexiq-api.onrender.com


# ── GITHUB SECRETS SUMMARY ─────────────────────────────────────
# Add all of these at: GitHub → Settings → Secrets → Actions
#
# Secret name              Where to get it
# ─────────────────────    ────────────────────────────────────────────────
# CLOUDFLARE_API_TOKEN     Cloudflare Dashboard → My Profile → API Tokens
#                          → Create Token → "Edit Cloudflare Workers" template
#                          Scopes needed: Account:Cloudflare Pages:Edit
#
# CLOUDFLARE_ACCOUNT_ID    Cloudflare Dashboard → right sidebar
#                          32-character hex string, e.g. a1b2c3d4e5...
#
# VITE_API_URL             Your Render URL: https://forexiq-api.onrender.com
#                          Used at build time to tell the frontend where the
#                          backend is (baked into JS bundle by Vite).
#
# RENDER_SERVICE_URL       Same as VITE_API_URL — used only by the
#                          post-deploy health check step in the workflow.
#                          https://forexiq-api.onrender.com
#
# NEWSDATA_API_KEY         From newsdata.io dashboard (starts with pub_)
#                          Optional here — also set directly in Render.
