# ──────────────────────────────────────────────────────
# ForexIQ Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────

# Server port (default 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=production

# The origin your frontend is served from (used for CORS lockdown)
# Example: https://forexiq.yourdomain.com
ALLOWED_ORIGIN=https://yourdomain.com

# NewsData.io API key (free tier, get yours at https://newsdata.io)
# IMPORTANT: In production, rotate this key and set it here rather
# than hardcoding it in routes.ts
NEWSDATA_API_KEY=your_newsdata_key_here
